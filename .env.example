# Server-only Google Apps Script booking integration.
# Never prefix these variables with NEXT_PUBLIC_.
GOOGLE_APPS_SCRIPT_WEB_APP_URL=
GOOGLE_APPS_SCRIPT_API_SECRET=

# MVP admin authentication. Use a strong password and a random secret of at least 32 characters.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Public canonical website origin. This is the only variable here allowed to use NEXT_PUBLIC_.
NEXT_PUBLIC_APP_URL=

# Optional future LINE Official Account integration. The current website does not require these.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
